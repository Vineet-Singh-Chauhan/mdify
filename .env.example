# ============================================================
# mdify — Environment Variable Reference
# Copy this file to .env and set real values before running.
# ============================================================

# --- Ports (host-published only; redis/clamav/worker are internal-only) ---
FRONTEND_PORT=3000
BACKEND_PORT=8000
BACKEND_PUBLIC_URL=http://localhost:8000

# --- CORS Allowed Origins (Comma-separated list of frontends) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-vercel-domain.vercel.app

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- ClamAV ---
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# --- Upload limits ---
MAX_UPLOAD_SIZE_MB=50

# --- Cleanup lifecycle ---
PURGE_INTERVAL_SECONDS=600

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
